!
class-map match-any HI
 match access-group name HI-Traffic
 match protocol bgp
 match protocol telnet
 match dscp cs3 
class-map match-any LO
 match access-group name LO-Traffic
 match protocol dns
 match protocol ntp
 match protocol telnet
 match protocol ssh
class-map match-any RT
 match access-group name RT-Traffic
 match protocol rtp
 match dscp ef 
 match protocol h323
 match protocol sip
 match protocol rtcp
 match access-group name avaya-voice-tty
class-map match-any LIVEACTION-CLASS-AVC
 match access-group name LIVEACTION-ACL-AVC
class-map match-any VIDEO
 match access-group name VIDEO-Traffic
class-map match-any SCAVENGER
 match access-group name SCAVENGER-Traffic
class-map match-any LIVEACTION-CLASS-MEDIANET
 match protocol rtp
 match protocol telepresence-media
!
policy-map QOS
 class RT
  priority percent 50
  set ip dscp ef
 class VIDEO
  bandwidth remaining percent 15 
  set ip dscp af41
 class HI
  bandwidth remaining percent 40 
  set ip dscp af31
  queue-limit 128 packets
 class LO
  bandwidth remaining percent 10 
  set ip dscp af21
  queue-limit 128 packets
 class SCAVENGER
  bandwidth remaining percent 5 
  set ip dscp af11
 class LIVEACTION-CLASS-AVC
 class class-default
  bandwidth remaining percent 30 
  set ip dscp default
  queue-limit 512 packets
policy-map CL_AVPN_20M
 class class-default
  shape average 20000000   
   service-policy QOS
