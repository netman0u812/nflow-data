version 17.9
service nagle
service tcp-keepalives-in
service tcp-keepalives-out
service timestamps debug datetime msec localtime show-timezone
service timestamps log datetime msec localtime show-timezone
service password-encryption
service compress-config
service sequence-numbers
service call-home
platform qfp utilization monitor load 80
no platform punt-keepalive disable-kernel-core
!
hostname rricrcp-mpls-distcenterlab-01
!
boot-start-marker
boot system bootflash:packages.conf
boot-end-marker
!
!
vrf definition Mgmt-intf
 !
 address-family ipv4
 exit-address-family
 !
 address-family ipv6
 exit-address-family
!
security passwords min-length 8
logging count
logging buffered 262144
no logging console
aaa new-model
!
!
aaa group server tacacs+ CVSHealth-ISE
 server name CVSHealth-ISE-RI-1
 server name CVSHealth-ISE-RI-2
 server name CVSHealth-ISE-AZ-1
 server name CVSHealth-ISE-AZ-2
!
aaa authentication password-prompt "Enter Local Password:"
aaa authentication username-prompt "Enter Local Username:"
aaa authentication login default group CVSHealth-ISE local
aaa authentication enable default group CVSHealth-ISE enable
aaa authorization console
aaa authorization config-commands
aaa authorization exec default group CVSHealth-ISE local 
aaa authorization commands 15 default group CVSHealth-ISE none 
aaa accounting exec default stop-only group CVSHealth-ISE
aaa accounting commands 15 default stop-only group CVSHealth-ISE
!
!
aaa session-id common
clock calendar-valid
!
!
!
!
!
!
!
ip name-server 10.228.144.15 10.228.144.20
ip domain name cvshealth.com
!
!
!
login block-for 60 attempts 5 within 60
login delay 5
login on-failure log every 2
login on-success log
!
!
!
!
!
!
!
subscriber templating
vtp mode transparent
vtp version 1
multilink bundle-name authenticated
!
flow record type performance-monitor LIVEACTION-FLOWRECORD-AVC
 description DO NOT MODIFY. USED BY LIVEACTION.
 collect application http host
 collect application ssl common-name
!
!
flow record type performance-monitor LIVEACTION-FLOWRECORD-MEDIANET
 description DO NOT MODIFY. USED BY LIVEACTION.
!
!
flow record LIVEACTION-FLOWRECORD
 description DO NOT MODIFY. USED BY LIVEACTION.
 match flow direction
 match interface input
 match ipv4 destination address
 match ipv4 protocol
 match ipv4 source address
 match ipv4 tos
 match transport destination-port
 match transport source-port
 collect application http host
 collect application name
 collect application ssl common-name
 collect counter bytes
 collect counter packets
 collect flow sampler
 collect interface output
 collect ipv4 destination mask
 collect ipv4 dscp
 collect ipv4 id
 collect ipv4 source mask
 collect ipv4 source prefix
 collect routing destination as
 collect routing next-hop address ipv4
 collect routing source as
 collect timestamp sys-uptime first
 collect timestamp sys-uptime last
 collect transport tcp flags
!
!
flow exporter LIVEACTION-FLOWEXPORTER-IPFIX
 description DO NOT MODIFY. USED BY LIVEACTION.
 destination 10.18.2.32
 source Loopback0
 transport udp 2055
 export-protocol ipfix
 option interface-table
 option vrf-table
 option sampler-table
 option application-table
 option c3pl-class-table
 option c3pl-policy-table
 option application-attributes
!
!
flow monitor LIVEACTION-FLOWMONITOR
 description DO NOT MODIFY. USED BY LIVEACTION.
 exporter LIVEACTION-FLOWEXPORTER-IPFIX
 cache timeout inactive 10
 cache timeout active 60
 record LIVEACTION-FLOWRECORD
!
!
flow monitor LIVEACTION-FLOWMONITOR-AVC
!
!
flow monitor LIVEACTION-FLOWMONITOR-MEDIANET
!
