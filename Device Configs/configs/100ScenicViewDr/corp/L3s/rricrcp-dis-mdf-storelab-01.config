 match access-group name HE-UnMarked-VC-Signaling-group
class-map match-any COS5-class
 match dscp cs1 
 match dscp af11 
 match dscp af12  af13 
class-map match-any HE-QoS-PassThru-class
 match access-group name HE-QoS-PassThru-128T-group
 match access-group name HE-QoS-PassThru-DMVPN-group
class-map match-any system-cpp-police-forus
  description Forus Address resolution and Forus traffic
class-map match-any COS1-class
 match dscp ef 
 match dscp cs5 
class-map match-any system-cpp-police-multicast-end-station
  description MCAST END STATION
class-map match-any COS2-class
 match dscp cs6 
 match dscp cs3 
 match dscp af31 
 match dscp af32  af33 
class-map match-any COS3-class
 match dscp cs2 
 match dscp af21 
 match dscp af22  af23 
class-map match-any system-cpp-police-high-rate-app
  description High Rate Applications 
class-map match-any system-cpp-police-multicast
  description MCAST Data
class-map match-any HE-UnMarked-VC-Video-Media-class
 match access-group name HE-UnMarked-VC-Video-Media-group
class-map match-any system-cpp-police-l2-control
  description L2 control
class-map match-any system-cpp-police-dot1x-auth
  description DOT1X Auth
class-map match-all HE-Voice-Signaling-class
 match ip dscp cs3 
 match access-group name HE-Voice-Signaling-group
class-map match-any system-cpp-police-data
  description ICMP redirect, ICMP_GEN and BROADCAST
class-map match-any system-cpp-police-stackwise-virt-control
  description Stackwise Virtual OOB
class-map match-all HE-Voice-Media-class
 match ip dscp ef 
 match access-group name HE-Voice-Media-group
class-map match-any non-client-nrt-class
class-map match-any system-cpp-police-routing-control
  description Routing control and Low Latency
class-map match-any system-cpp-police-protocol-snooping
  description Protocol snooping
class-map match-any system-cpp-police-dhcp-snooping
  description DHCP snooping
class-map match-any system-cpp-police-ios-routing
  description L2 control, Topology control, Routing control, Low Latency
class-map match-any system-cpp-police-system-critical
  description System Critical and Gold Pkt
class-map match-all HE-Marked-VC-Video-Media-class
 match ip dscp af31  af32  af33 
 match access-group name HE-Marked-VC-Video-Media-group
class-map match-any system-cpp-police-ios-feature
  description ICMPGEN,BROADCAST,ICMP,L2LVXCntrl,ProtoSnoop,PuntWebauth,MCASTData,Transit,DOT1XAuth,Swfwd,LOGGING,L2LVXData,ForusTraffic,ForusARP,McastEndStn,Openflow,Exception,EGRExcption,NflSampled,RpfFailed
class-map match-any Bursty-High-class
 match dscp af31 
 match access-group name Bursty-High-group
class-map match-all HE-Marked-VC-Audio-Media-class
 match ip dscp ef 
 match access-group name HE-Marked-VC-Audio-Media-group
!
policy-map CVS-HE-Shape-WAN
 class COS1-class
 class COS2-class
  bandwidth remaining percent 40 
  random-detect dscp-based
 class COS3-class
  bandwidth remaining percent 30 
  random-detect dscp-based
 class COS5-class
  bandwidth remaining percent 1 
  random-detect dscp-based
 class class-default
  bandwidth remaining percent 29 
  set dscp default
  random-detect
policy-map system-cpp-policy
policy-map CVS-HE-Mark-LAN-6COS-n-PassThru
 class HE-WAN-Edge-Loopback0-class
 class HE-Voice-Media-class
 class HE-Voice-Signaling-class
 class HE-Marked-VC-Video-Media-class
 class HE-Marked-VC-Audio-Media-class
 class HE-Marked-VC-Signaling-class
 class HE-QoS-PassThru-class
 class Bursty-High-class
  set dscp af31
 class Bursty-Low-class
  set dscp af21
 class Bulky-Data-class
  set dscp af11
 class HE-UnMarked-VC-Video-Media-class
  set dscp af42
 class HE-UnMarked-VC-Signaling-class
  set dscp af23
 class class-default
  set dscp default
