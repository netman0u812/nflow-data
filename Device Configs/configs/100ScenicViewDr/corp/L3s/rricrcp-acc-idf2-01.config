version 17.9
service nagle
service tcp-keepalives-in
service tcp-keepalives-out
service timestamps debug datetime msec localtime show-timezone
service timestamps log datetime msec localtime show-timezone
service password-encryption
service sequence-numbers
service call-home
platform punt-keepalive disable-kernel-core
!
hostname rricrcp-acc-idf2-01
!
!
vrf definition Mgmt-vrf
 !
 address-family ipv4
 exit-address-family
 !
 address-family ipv6
 exit-address-family
!
logging count
logging buffered 262144
no logging console
aaa new-model
!
!
aaa group server tacacs+ CVSHealth-ISE
 server name CVSHealth-ISE-RI-1
 server name CVSHealth-ISE-RI-2
 server name CVSHealth-ISE-AZ-1
 server name CVSHealth-ISE-AZ-2
!
aaa authentication password-prompt "Enter Local Password:"
aaa authentication username-prompt "Enter Local Username:"
aaa authentication login default group CVSHealth-ISE local
aaa authentication enable default group CVSHealth-ISE enable
aaa authorization console
aaa authorization config-commands
aaa authorization exec default group CVSHealth-ISE local 
aaa authorization commands 15 default group CVSHealth-ISE none 
aaa accounting exec default stop-only group CVSHealth-ISE
aaa accounting commands 15 default stop-only group CVSHealth-ISE
!
!
aaa session-id common
switch 1 provision c9300-48u
switch 2 provision c9300-48u
switch 3 provision c9300-48u
switch 4 provision c9300-48u
switch 5 provision c9300-48u
